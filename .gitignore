# ==========================================
# Project - Root .gitignore
# Backend: Spring Boot (Maven/Gradle)
# Frontend: React (Node)
# ==========================================

# ==========================================
# General
# ==========================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*.swo

# ==========================================
# Environment Files
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# IDEs
# ==========================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
out/

.project
.classpath
.settings/

# ==========================================
# BACKEND (Spring Boot)
# ==========================================

# Maven
backend/target/

# Gradle
backend/.gradle/
backend/build/

# Compiled classes
backend/**/*.class

# Logs
backend/logs/

# Spring Boot Devtools
backend/.restart

# ==========================================
# FRONTEND (React)
# ==========================================

# Node dependencies
frontend/node_modules/

# Build output
frontend/build/
frontend/dist/

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Coverage
frontend/coverage/

# Cache
frontend/.cache/
frontend/.parcel-cache/
frontend/.next/


# ==========================================
# Misc
# ==========================================
*.pid
*.seed
*.pid.lock
